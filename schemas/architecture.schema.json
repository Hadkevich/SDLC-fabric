{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Architecture",
    "type": "object",
    "required": ["spec_version", "workflow_id", "components", "runtime", "persistence", "failure_modes"],
    "additionalProperties": false,
    "properties": {
        "spec_version": { "type": "string", "const": "v1" },
        "workflow_id": { "type": "string" },
        "components": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["id", "name", "type", "responsibilities", "interfaces"],
                "additionalProperties": false,
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "type": {
                        "type": "string",
                        "enum": ["service", "library", "cli", "worker", "gateway", "store"]
                    },
                    "responsibilities": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "interfaces": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["name", "type"],
                            "properties": {
                                "name": { "type": "string" },
                                "type": { "type": "string", "enum": ["http", "grpc", "cli", "file", "queue", "sdk"] },
                                "ref": { "type": "string" }
                            }
                        }
                    },
                    "depends_on": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                }
            }
        },
        "runtime": {
            "type": "object",
            "required": ["language", "runtime_version"],
            "properties": {
                "language": { "type": "string" },
                "runtime_version": { "type": "string" },
                "framework": { "type": "string" },
                "build_command": { "type": "string" },
                "start_command": { "type": "string" }
            }
        },
        "persistence": {
            "type": "object",
            "required": ["type"],
            "properties": {
                "type": { "type": "string", "enum": ["sqlite", "postgres", "mysql", "file", "redis", "none"] },
                "migrations": { "type": "boolean" },
                "schema_ref": { "type": "string" }
            }
        },
        "failure_modes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["scenario", "mitigation"],
                "properties": {
                    "scenario": { "type": "string" },
                    "mitigation": { "type": "string" }
                }
            }
        },
        "adrs": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "ref"],
                "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "ref": { "type": "string" }
                }
            }
        },
        "api_contracts_ref": { "type": "string" },
        "data_model_ref": { "type": "string" }
    }
}
