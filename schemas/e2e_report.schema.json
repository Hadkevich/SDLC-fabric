{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "E2EReport",
    "type": "object",
    "required": ["spec_version", "workflow_id", "base_url", "scenarios", "summary", "verdict", "validated_at"],
    "additionalProperties": false,
    "properties": {
        "spec_version": { "type": "string", "const": "v1" },
        "workflow_id": { "type": "string" },
        "task_id": { "type": "string" },
        "base_url": { "type": "string" },
        "browser": { "type": "string" },
        "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["scenario_id", "name", "status"],
                "additionalProperties": false,
                "properties": {
                    "scenario_id": { "type": "string" },
                    "name": { "type": "string" },
                    "maps_to_requirement": { "type": "string" },
                    "steps": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "given": { "type": "string" },
                    "when": { "type": "string" },
                    "then": { "type": "string" },
                    "status": {
                        "type": "string",
                        "enum": ["pass", "fail", "skip", "pending"]
                    },
                    "error": { "type": "string" },
                    "screenshot_ref": { "type": "string" }
                }
            }
        },
        "summary": {
            "type": "object",
            "required": ["total", "passed", "failed", "skipped"],
            "additionalProperties": false,
            "properties": {
                "total": { "type": "integer" },
                "passed": { "type": "integer" },
                "failed": { "type": "integer" },
                "skipped": { "type": "integer" },
                "coverage_note": { "type": "string" }
            }
        },
        "verdict": {
            "type": "string",
            "enum": ["passed", "passed_with_warnings", "failed"]
        },
        "validated_at": { "type": "string", "format": "date-time" }
    }
}
