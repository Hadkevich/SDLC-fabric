{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "TestPlan",
    "type": "object",
    "required": ["spec_version", "workflow_id", "test_suites", "summary"],
    "additionalProperties": false,
    "properties": {
        "spec_version": { "type": "string", "const": "v1" },
        "workflow_id": { "type": "string" },
        "test_suites": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["suite_id", "name", "owner_agent", "test_cases"],
                "additionalProperties": false,
                "properties": {
                    "suite_id": { "type": "string" },
                    "name": { "type": "string" },
                    "owner_agent": { "type": "string" },
                    "test_cases": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["test_id", "name", "given", "when", "then", "status"],
                            "additionalProperties": false,
                            "properties": {
                                "test_id": { "type": "string" },
                                "name": { "type": "string" },
                                "given": { "type": "string" },
                                "when": { "type": "string" },
                                "then": { "type": "string" },
                                "status": {
                                    "type": "string",
                                    "enum": ["pass", "fail", "skip", "pending"]
                                },
                                "error": { "type": "string" },
                                "maps_to_requirement": { "type": "string" }
                            }
                        }
                    }
                }
            }
        },
        "summary": {
            "type": "object",
            "additionalProperties": false,
            "required": ["total", "passed", "failed", "skipped"],
            "properties": {
                "total": { "type": "integer" },
                "passed": { "type": "integer" },
                "failed": { "type": "integer" },
                "skipped": { "type": "integer" },
                "coverage_note": { "type": "string" }
            }
        }
    }
}
