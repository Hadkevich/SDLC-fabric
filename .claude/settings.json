{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest tests/)",
      "Bash(python3 -m pytest tests/:*)",
      "Bash(PYTHONPATH=src python3 -m orchestrator:*)",
      "Bash(./observability/serve.sh:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ]
  }
}
