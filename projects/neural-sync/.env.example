# NEURAL SYNC — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# ── LLM (Google Gemini — free tier) ──────────────────────────────────────────
# Required for AI match explanations. Get a free key (30s, no billing):
#   https://aistudio.google.com/app/apikey
# Without it the app still runs, but explanations stay as deterministic stubs.
GEMINI_API_KEY=
# Optional concurrency knobs (defaults are fine for the pilot)
# CLAUDE_MAX_CONCURRENT=5
# CLAUDE_QUEUE_MAX_DEPTH=50

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neuralsync:neuralsync@localhost:5432/neuralsync
DATABASE_URL_SYNC=postgresql://neuralsync:neuralsync@localhost:5432/neuralsync

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong value for shared/deployed environments, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NEURAL_SYNC_JWT_SECRET=dev-secret-change-in-production

# ── CORS / cookies ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# ── Data Ingestion Connectors ────────────────────────────────────────────────
# GitLab connector [AC28]
# GITLAB_BASE_URL: GitLab instance URL (default: https://gitlab.com for SaaS).
#   Override for self-managed GitLab installations, e.g. https://gitlab.example.com
GITLAB_BASE_URL=https://gitlab.com
# GITLAB_TOKEN: optional personal access token for reading private repositories.
#   Without it only public data is accessible (connector remains 'live').
#   Generate at: https://gitlab.com/-/profile/personal_access_tokens (read_api scope)
GITLAB_TOKEN=
# GITLAB_MAX_PAGES: maximum pages per paginated GitLab API request (default 10).
#   Reduce to limit network calls; increase to retrieve deeper history.
GITLAB_MAX_PAGES=10

# Jira connector [AC28]
# All four variables are required for credential-gated Jira access.
# JIRA_BASE_URL: Jira Cloud or Server URL (e.g. https://myorg.atlassian.net)
JIRA_BASE_URL=
# JIRA_EMAIL: email address of the Jira account used for Basic Auth
JIRA_EMAIL=
# JIRA_TOKEN: Jira API token for Basic Auth (generate at id.atlassian.com)
JIRA_TOKEN=

# File upload and batch limits [AC28]
# MAX_UPLOAD_BYTES: maximum allowed multipart file body size in bytes.
#   Requests exceeding this limit receive HTTP 413 before any parsing.
#   Default: 10485760 (10 MiB)
MAX_UPLOAD_BYTES=10485760
# INGESTION_MAX_RECORDS: maximum number of profiles processed per ingestion batch.
#   Batches larger than this cap are truncated; surplus records are noted in errors.
#   Default: 500
INGESTION_MAX_RECORDS=500

# ── Embeddings ───────────────────────────────────────────────────────────────
# EMBEDDING_DIM: pgvector column dimension. MUST match the active backend and the
#   migrated columns. Default 1536 (random/OpenAI backends, the seed, and the HNSW
#   indexes). Only set 384 if you run sentence-transformers AND re-migrate the columns.
# EMBEDDING_DIM=1536
# OPENAI_API_KEY=               # optional: 1536-dim OpenAI embeddings (else deterministic random)

# ── Continuous re-optimization (Task04 §4) ───────────────────────────────────
# NEURAL_SYNC_REOPT_INTERVAL: seconds between background risk-cache refreshes.
#   0 / unset (default) = disabled. >0 enables the APScheduler loop (e.g. 3600 = hourly).
# NEURAL_SYNC_REOPT_INTERVAL=0

# ── Misc ─────────────────────────────────────────────────────────────────────
DEBUG=false
# PORT=8080                     # used by the Docker image
