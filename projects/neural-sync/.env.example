# NEURAL SYNC — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# ── LLM (Google Gemini — free tier) ──────────────────────────────────────────
# Required for AI match explanations. Get a free key (30s, no billing):
#   https://aistudio.google.com/app/apikey
# Without it the app still runs, but explanations stay as deterministic stubs.
GEMINI_API_KEY=
# Optional concurrency knobs (defaults are fine for the pilot)
# CLAUDE_MAX_CONCURRENT=5
# CLAUDE_QUEUE_MAX_DEPTH=50

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neuralsync:neuralsync@localhost:5432/neuralsync
DATABASE_URL_SYNC=postgresql://neuralsync:neuralsync@localhost:5432/neuralsync

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong value for shared/deployed environments, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NEURAL_SYNC_JWT_SECRET=dev-secret-change-in-production

# ── CORS / cookies ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# ── Misc ─────────────────────────────────────────────────────────────────────
DEBUG=false
# PORT=8080                     # used by the Docker image
# OPENAI_API_KEY=               # optional: switches embeddings to OpenAI (else local sentence-transformers)
